# === Required ===
AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_ENDPOINT=https://westeurope.api.cognitive.microsoft.com/

# === Optional: OpenAI (enables LLMReasoner) ===
# OPENAI_API_KEY=sk-...    # also supports OpenRouter keys like sk-or-...
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# === Optional: Azure Speech free tier tracking ===
# AZURE_SPEECH_FREE_MINUTES=300

# === Optional: Full avatar video service ===
# AVATAR_API_URL=https://your-avatar-provider.example/v1/generate
# AVATAR_API_KEY=sk-...
# AVATAR_MODEL=default-avatar
# AVATAR_CHARACTER=lisa
# AVATAR_STYLE=casual-sitting

# === Optional: Groq (native client) ===
# GROQ_API_KEY=gsk-...
# GROQ_API_BASE_URL=https://api.groq.ai/v1
# GROQ_MODEL=llama-3.3-70b-versatile

# === Optional: Azure OpenAI (alternative LLM backend) ===
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# === App settings ===
# LOG_LEVEL=INFO
# HOST=0.0.0.0
# PORT=8000
